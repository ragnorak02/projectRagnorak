[resource]
script = ExtResource("1")
quest_id = &"fetch_herbs"
title = "Herbal Remedy"
description = "The village herbalist needs fresh herbs from the nearby field. Gather 3 herbs and bring them back."
quest_type = 1
objectives = [SubResource("obj1"), SubResource("obj2")]
