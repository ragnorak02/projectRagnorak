; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but it can also be edited with a text editor.

[application]

config/name="Project Ragnorak"
config/description="Korean Fantasy Hybrid Action RPG"
run/main_scene="res://scenes/menus/main_menu.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")

[autoload]

Events="*res://scripts/autoloads/events.gd"
GameManager="*res://scripts/autoloads/game_manager.gd"
InputManager="*res://scripts/autoloads/input_manager.gd"
AudioManager="*res://scripts/autoloads/audio_manager.gd"
SaveManager="*res://scripts/autoloads/save_manager.gd"
DebugFlags="*res://scripts/autoloads/debug_flags.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=2
window/stretch/mode="canvas_items"

